<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/ai_drawer_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="10dp">

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/model_source_toggle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:singleSelection="true"
        app:selectionRequired="true">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/model_source_local"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Local" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/model_source_hf"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="HuggingFace" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/model_source_cloud"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Gemini" />
    </com.google.android.material.button.MaterialButtonToggleGroup>

    <LinearLayout
        android:id="@+id/model_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="8dp">

        <LinearLayout
            android:id="@+id/local_controls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_pick_local_model"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pick model from storage" />

            <TextView
                android:id="@+id/txt_local_model_path"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No model selected"
                android:textSize="12sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/hf_controls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="8dp"
            android:visibility="gone">

            <EditText
                android:id="@+id/edt_hf_repo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="HF repo (e.g. TheBloke/Model-GGUF)"
                android:inputType="text" />

            <EditText
                android:id="@+id/edt_hf_filename"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="File (e.g. model.Q4_K_M.gguf)"
                android:inputType="text"
                android:layout_marginTop="6dp" />

            <EditText
                android:id="@+id/edt_hf_token"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="HF token (optional)"
                android:inputType="textPassword"
                android:layout_marginTop="6dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_download_hf"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Download model"
                android:layout_marginTop="6dp" />

            <TextView
                android:id="@+id/txt_hf_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cloud_controls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="8dp"
            android:visibility="gone">

            <EditText
                android:id="@+id/edt_gemini_api_key"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Gemini API key"
                android:inputType="textPassword" />

            <EditText
                android:id="@+id/edt_gemini_model"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Model (e.g. gemini-2.0-flash)"
                android:inputType="text"
                android:layout_marginTop="6dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save_cloud"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Save"
                android:layout_marginTop="6dp" />

            <TextView
                android:id="@+id/txt_cloud_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/ai_chat_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="always"
        android:layout_marginTop="10dp" />

    <LinearLayout
        android:id="@+id/ai_input_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <ImageButton
            android:id="@+id/btn_attach_file"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@null"
            android:contentDescription="Attach file"
            android:src="@android:drawable/ic_menu_upload" />

        <EditText
            android:id="@+id/edt_ai_message"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Message…"
            android:inputType="textMultiLine"
            android:maxLines="4"
            android:minLines="1"
            android:layout_marginHorizontal="8dp" />

        <ImageButton
            android:id="@+id/btn_send"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@null"
            android:contentDescription="Send"
            android:src="@android:drawable/ic_menu_send" />
    </LinearLayout>

</LinearLayout>
