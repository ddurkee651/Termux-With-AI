<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/ai_msg_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="10dp"
    android:paddingEnd="10dp"
    android:paddingTop="6dp"
    android:paddingBottom="6dp">

    <LinearLayout
        android:id="@+id/ai_msg_bubble"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:background="#1E232B">

        <TextView
            android:id="@+id/ai_msg_meta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:text=""
            android:textColor="#AEB6C2"
            android:paddingBottom="6dp" />

        <TextView
            android:id="@+id/ai_msg_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:lineSpacingExtra="2dp"
            android:text=""
            android:textColor="#E9EDF1"
            android:textIsSelectable="true" />

        <TextView
            android:id="@+id/ai_msg_attachments"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:text=""
            android:textColor="#C9D1DB"
            android:paddingTop="8dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/ai_msg_error"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:text=""
            android:textColor="#FFB4AB"
            android:paddingTop="8dp"
            android:visibility="gone" />
    </LinearLayout>

</LinearLayout>
